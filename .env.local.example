# Stripe Keys
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Price IDs
# Create these in your Stripe dashboard or use the Stripe CLI
# These placeholder IDs are used in the pricing section:
#   price_starter_monthly    → Starter   $149/mo
#   price_pro_monthly        → Pro       $299/mo
#   price_business_monthly   → Business  $599/mo
#   price_enterprise_monthly → Enterprise $1499/mo
